# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: your stable public URL (fixed domain), for docs/display only.
PUBLIC_URL="https://bi.example.com"

# Cloudflare Named Tunnel token (from Cloudflare Zero Trust dashboard).
CLOUDFLARE_TUNNEL_TOKEN="MY_CLOUDFLARE_TUNNEL_TOKEN"

# Optional local preview port for tunnel target.
CLOUDFLARE_LOCAL_PORT="4173"
